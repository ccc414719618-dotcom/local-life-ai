#!/bin/bash
# 用户端 AI 对接脚本 - CLI 工具
# 让 AI Agent 能更容易地操作

set -e

PLATFORM="http://localhost:3000"
CONFIG_FILE="$HOME/.config/local-life-ai/user-config.json"

# 颜色输出
RED='\033[0;31m'
GREEN='\033[0;32m'
YELLOW='\033[1;33m'
NC='\033[0m'

# 检查配置
check_config() {
  if [ ! -f "$CONFIG_FILE" ]; then
    echo -e "${RED}错误：未找到用户配置${NC}"
    echo "请先运行安装脚本："
    echo "curl http://localhost:3000/skills/user-connector/install.sh | bash"
    exit 1
  fi
}

# 解析用户偏好
parse_preferences() {
  if [ -f "$CONFIG_FILE" ]; then
    user_name=$(grep -o '"name":"[^"]*"' "$CONFIG_FILE" | head -1 | cut -d'"' -f4)
    diet=$(grep -o '"diet":"[^"]*"' "$CONFIG_FILE" | cut -d'"' -f4)
    allergens=$(grep -o '"allergens":"[^"]*"' "$CONFIG_FILE" | cut -d'"' -f4)
    goal=$(grep -o '"goal":"[^"]*"' "$CONFIG_FILE" | cut -d'"' -f4)
  fi
}

# 搜索服务
search() {
  check_config
  local query="$1"
  local url="${PLATFORM}/mcp/search?q=$(echo "$query" | sed 's/ /+/g')"
  
  echo -e "${GREEN}搜索: $query${NC}"
  curl -s "$url" | python3 -c "
import sys, json
try:
  data = json.load(sys.stdin)
  results = data.get('results', [])
  if not results:
    print('未找到结果')
    sys.exit(0)
  print(f'找到 {len(results)} 个结果:\\n')
  for r in results:
    name = r.get('name', '未知')
    addr = r.get('location', {}).get('address', '未知地址')
    caps = ', '.join(r.get('capabilities', []))
    print(f'【{name}】')
    print(f'  地址: {addr}')
    print(f'  服务: {caps}')
    print()
except: print('搜索失败')
"
}

# 发现附近服务
discover() {
  check_config
  parse_preferences
  
  echo -e "${GREEN}发现附近服务 (用户: ${user_name:-未知}) ${NC}"
  echo -e "偏好: ${diet:-无} | 过敏: ${allergens:-无} | 目标: ${goal:-无}"
  echo ""
  
  curl -s "${PLATFORM}/mcp-manifest.json" | python3 -c "
import sys, json
try:
  data = json.load(sys.stdin)
  services = data.get('services', [])
  print(f'平台共有 {len(services)} 个服务\\n')
  for s in services:
    print(f'【{s.get(\"name\")}】')
    print(f'  分类: {\", \".join(s.get(\"categories\", []))}')
    print(f'  地址: {s.get(\"location\", {}).get(\"address\", \"未知\")}')
    print(f'  端点: {s.get(\"endpoint\")}')
    print()
except: print('获取失败')
"
}

# 获取服务详情
info() {
  local service_id="$1"
  if [ -z "$service_id" ]; then
    echo "用法: llai info <服务ID>"
    exit 1
  fi
  
  echo -e "${GREEN}获取服务详情: $service_id${NC}"
  curl -s "${PLATFORM}/mcp/${service_id}/manifest.json" | python3 -c "
import sys, json
try:
  data = json.load(sys.stdin)
  print(f'名称: {data.get(\"service_name\")}')
  print(f'地址: {data.get(\"location\", {}).get(\"address\", \"未知\")}')
  print(f'营业: {data.get(\"location\", {}).get(\"hours\", \"未知\")}')
  print(f'服务: {', '.join(data.get(\"capabilities\", []))}')
  print()
  print('可用工具:')
  for t in data.get('tools', []):
    print(f'  - {t.get(\"name\")}: {t.get(\"description\")}')
except: print('获取失败')
"
}

# 排队状态
queue_status() {
  local service_id="$1"
  if [ -z "$service_id" ]; then
    echo "用法: llai queue <服务ID>"
    exit 1
  fi
  
  echo -e "${GREEN}查询排队状态: $service_id${NC}"
  curl -s -X POST "${PLATFORM}/mcp/${service_id}/call" \
    -H "Content-Type: application/json" \
    -d '{"tool":"get_queue_status"}' | python3 -c "
import sys, json
try:
  data = json.load(sys.stdin)
  r = data.get('result', {})
  print(f'当前等待: {r.get(\"current_wait\", 0)} 桌')
  print(f'预计等待: {r.get(\"avg_wait_minutes\", 0)} 分钟')
  print()
  print('可用桌位:')
  for t in r.get('available_tables', []):
    status = '✅ 可用' if t.get('available') else '❌ 占用'
    print(f'  {t.get(\"name\")}: {status}')
except: print('获取失败')
"
}

# 取号
take_queue() {
  local service_id="$1"
  local table_type="${2:-1}"
  local people="${3:-2}"
  
  if [ -z "$service_id" ]; then
    echo "用法: llai take <服务ID> [桌型] [人数]"
    echo "  桌型: 1=小桌(2人) 2=中桌(4人) 3=大桌(6人)"
    exit 1
  fi
  
  echo -e "${GREEN}取号: $service_id${NC}"
  curl -s -X POST "${PLATFORM}/mcp/${service_id}/call" \
    -H "Content-Type: application/json" \
    -d "{\"tool\":\"take_queue_number\",\"parameters\":{\"table_type_id\":$table_type,\"people_count\":$people}}" | python3 -c "
import sys, json
try:
  data = json.load(sys.stdin)
  r = data.get('result', {})
  print(f'取号成功！')
  print(f'排队号: {r.get(\"queue_number\")}')
  print(f'预计等待: {r.get(\"estimated_wait_minutes\")} 分钟')
  print(f'桌型: {r.get(\"table_type\")}')
  print(f'状态: {r.get(\"status\")}')
except: print('取号失败')
"
}

# 预约座位
book() {
  local service_id="$1"
  local date="$2"
  local time="$3"
  local people="${4:-2}"
  
  if [ -z "$service_id" ] || [ -z "$date" ] || [ -z "$time" ]; then
    echo "用法: llai book <服务ID> <日期> <时间> [人数]"
    echo "示例: llai book jin_001 2024-04-21 19:00 3"
    exit 1
  fi
  
  echo -e "${GREEN}预约: $service_id${NC}"
  curl -s -X POST "${PLATFORM}/mcp/${service_id}/call" \
    -H "Content-Type: application/json" \
    -d "{\"tool\":\"book_table\",\"parameters\":{\"date\":\"$date\",\"time\":\"$time\",\"people_count\":$people}}" | python3 -c "
import sys, json
try:
  data = json.load(sys.stdin)
  r = data.get('result', {})
  print(f'预约成功！')
  print(f'预约号: {r.get(\"booking_id\")}')
  print(f'日期: {r.get(\"date\")} {r.get(\"time\")}')
  print(f'人数: {r.get(\"people_count\")}')
  print(f'状态: {r.get(\"status\")}')
except: print('预约失败')
"
}

# 帮助
help() {
  echo "╔══════════════════════════════════════════════════════╗"
  echo "║  🏪 本地生活 AI - 用户 CLI                    ║"
  echo "╚══════════════════════════════════════════════════════╝"
  echo ""
  echo "用法: llai <命令> [参数]"
  echo ""
  echo "命令:"
  echo "  discover          发现附近所有服务"
  echo "  search <关键词>    搜索服务"
  echo "  info <服务ID>      获取服务详情"
  echo "  queue <服务ID>     查询排队状态"
  echo "  take <服务ID>      取号排队"
  echo "  book <服务ID>      预约座位"
  echo "  help              显示帮助"
  echo ""
  echo "示例:"
  echo "  llai discover              # 发现附近服务"
  echo "  llai search 饺子           # 搜索饺子店"
  echo "  llai info jin_001          # 查看金谷园详情"
  echo "  llai queue jin_001         # 查看金谷园排队"
  echo "  llai take jin_001 1 2      # 金谷园小桌2人取号"
  echo "  llai book jin_001 2024-04-21 19:00 3  # 预约"
  echo ""
}

# 主命令路由
case "$1" in
  discover) discover ;;
  search) search "$2" ;;
  info) info "$2" ;;
  queue) queue_status "$2" ;;
  take) take_queue "$2" "$3" "$4" ;;
  book) book "$2" "$3" "$4" "$5" ;;
  help|--help|-h) help ;;
  *) 
    if [ -z "$1" ]; then
      help
    else
      echo -e "${RED}未知命令: $1${NC}"
      help
      exit 1
    fi
    ;;
esac
